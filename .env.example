# Chave da API Elsevier/Scopus. Nunca versione a chave real no repositório.
SCOPUS_API_KEY=chave_scopus_aqui

# Define se o script deve consultar a Scopus. Use 0 para reaproveitar apenas o cache local.
ATUALIZAR_SCOPUS=1

# Define se todos os ISSNs serão reconsultados, mesmo que já existam no cache.
# Use 1 apenas quando quiser refazer a coleta do zero.
SCOPUS_FORCE_REFRESH=0

# Salva o JSON bruto retornado pela Scopus em output/scopus_raw/.
# Use 1 apenas se precisar auditar a resposta completa da API.
SCOPUS_SALVAR_RAW=0

# View usada na Serial Title API. STANDARD atende às métricas usadas na modelagem atual.
SCOPUS_VIEW=STANDARD

# Intervalo entre requisições, em segundos. 0.25 mantém a coleta abaixo de ~4 req/s.
SCOPUS_INTERVALO_SEGUNDOS=0.25

# Tempo máximo de espera por requisição, em segundos.
SCOPUS_TIMEOUT=30

# Quantidade de novas tentativas para falhas transitórias, como 429, 500, 502, 503 e 504.
SCOPUS_MAX_RETRIES=3
